        LabelOne.Outline  = true
        LabelOne.Size     = 18
        LabelOne.Center   = true
        LabelOne.Visible  = true
        LabelOne.Text     = 'Silent Aim'
        LabelOne.Position = Vector2.new(vp.X / 2, offsetY)
        -- at size 13, "Silent Aim" ≈ 70px wide, half = 35; sub goes right after with 4px gap
        local targetName = SATarget and ('(' .. SATarget.DisplayName .. ')') or '(N/A)'
        LabelOneSub.Color    = Color3.fromRGB(0, 255, 0)
