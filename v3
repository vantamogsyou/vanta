local CachedPing,LastPingUpdate = 0.05,0
local function GetCachedPing()
    local now=tick()
    if now-LastPingUpdate>2 then
        LastPingUpdate=now
        pcall(function() CachedPing=game:GetService("Stats").Network.ServerStatsItem["Data Ping"]:GetValue()/1000 end)
        if CachedPing<0.01 then CachedPing=0.03 end
    end
    return CachedPing
end


