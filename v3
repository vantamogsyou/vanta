local function IsValidAddress(o) return o~=nil and typeof(o)=="Instance" and o.Parent~=nil end
local function IsChatOpen() return UserInputService:GetFocusedTextBox()~=nil end

local function HoldingKnife()
    if not flags.knifecheck then return false end
    local char=LocalPlayer.Character; if not char then return false end
    local tool=char:FindFirstChildOfClass("Tool"); return tool and tool.Name=="[Knife]"
end

local function PlayerKnocked(p)
    if not flags.knockedcheck or not p.Character then return false end
    local be=p.Character:FindFirstChild("BodyEffects")
    return be and be:FindFirstChild("K.O") and be["K.O"].Value
end

local function PlayerDead(p)
    if not p.Character then return true end
    local be=p.Character:FindFirstChild("BodyEffects")
    if be then
        local d=be:FindFirstChild("Dead"); if d and d.Value then return true end
        local k=be:FindFirstChild("K.O");  if k and k.Value then return true end
    end
    local h=p.Character:FindFirstChildOfClass("Humanoid"); return h and h.Health<=0
end

local function IsChatOpen() return UserInputService:GetFocusedTextBox()~=nil end

local function UpdateAimGUI(active)
    if not flags.hideaimgui then return end
    local pg=LocalPlayer:FindFirstChild("PlayerGui"); if not pg then return end
    local function scan(parent)
        for _,child in pairs(parent:GetChildren()) do
            if child.Name=="Aim" and child:IsA("GuiObject") then
                if active then
                    if not child:GetAttribute("OriginalSize") then child:SetAttribute("OriginalSize",child.Size) end
                    child.Size=UDim2.new(0,0,0,0)
                else
                    local orig=child:GetAttribute("OriginalSize"); if orig then child.Size=orig end
                end
            elseif child:IsA("GuiObject") or child:IsA("ScreenGui") then scan(child) end
        end
    end
    scan(pg)
end

local function CanSee(part)
    if not flags.vischeck or not part or not part.Parent then return true end
    RayParams.FilterDescendantsInstances={LocalPlayer.Character,part.Parent}
    local r=Workspace:Raycast(Camera.CFrame.Position,part.Position-Camera.CFrame.Position,RayParams)
    return r==nil or r.Instance:IsDescendantOf(part.Parent)
end

local function GetEffectiveFOV()
    if not flags.gunfov then return flags.fovsize or 200 end
    local char=LocalPlayer.Character; if not char then return flags.fovsize or 200 end
    local tool=char:FindFirstChildOfClass("Tool"); if not tool then return flags.fovsize or 200 end
    local n=tool.Name:lower()
    if n:find("double-barrel") or n:find("double barrel") then return flags.fovdb or 80
    elseif n:find("tacticalshotgun") or n:find("tactical shotgun") then return flags.fovts or 100
    elseif n:find("revolver") then return flags.fovrev or 90 end
    return flags.fovsize or 200
end

local function GetClosestBodyPart(char,mp)
    local best,bd=nil,math_huge
    for _,name in ipairs({"Head","HumanoidRootPart","UpperTorso","LowerTorso"}) do
        local p=char:FindFirstChild(name); if not IsValidAddress(p) then continue end
        local sp,on=Camera:WorldToViewportPoint(p.Position)
        local d=(not on or sp.Z<=0) and 999999 or math_sqrt((sp.X-mp.X)^2+(sp.Y-mp.Y)^2)
        if d<bd then bd=d; best=p end
    end
    return best
end

local function GetTargetPart(char,mp)
    local partName = flags.sahitpart or "Head"
    return char:FindFirstChild(partName) or char:FindFirstChild("Head") or char:FindFirstChild("HumanoidRootPart")
end

local function IsAirborne(char)
    if not char then return false end
    local h=char:FindFirstChildOfClass("Humanoid"); if not h then return false end
    local s=h:GetState()
    if s==Enum.HumanoidStateType.Freefall or s==Enum.HumanoidStateType.Flying or s==Enum.HumanoidStateType.Jumping then return true end
    local hrp=char:FindFirstChild("HumanoidRootPart")
    if hrp then local v=hrp.AssemblyLinearVelocity or hrp.Velocity; if math_abs(v.Y)>5 then return true end end
    return false
end

local function GetPredictedPos(part,char)
    if not flags.prediction or not part or not part:IsA("BasePart") then return part.Position end
    local vel=part.AssemblyLinearVelocity or part.Velocity
    local pred=(flags.predamount or 0.13)*math_max((part.Position-Camera.CFrame.Position).Magnitude/50,0.4)+GetCachedPing()
    local grav=Vector3_new(0,0,0)
    if IsAirborne(char) then pred=pred*1.4; grav=Vector3_new(0,-0.5*(Workspace.Gravity or 196.2)*pred*pred,0) end
    return part.Position+vel*pred+grav
end

local function FindClosestToMouse(ignoreFOV)
    if HoldingKnife() then return nil end
    local mp=UserInputService:GetMouseLocation()
    local fovSq=(not ignoreFOV and flags.silentfov) and GetEffectiveFOV()^2 or math_huge
    local best,bd=nil,math_huge
    for _,p in pairs(Players:GetPlayers()) do
        if p==LocalPlayer or not p.Character then continue end
        local head=p.Character:FindFirstChild("Head"); if not head then continue end
        if PlayerDead(p) or PlayerKnocked(p) then continue end
        local sp,on=Camera:WorldToViewportPoint(head.Position); if not on or sp.Z<=0 then continue end
        local d=(mp.X-sp.X)^2+(mp.Y-sp.Y)^2
        if d>fovSq or not CanSee(head) then continue end
        if d<bd then bd=d; best=p end
    end
    return best
end


