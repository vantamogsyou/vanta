local function RefreshTargetHUD()
    if not flags.targethud then tHudFrame.Visible = false return end
    local mode = flags.hudtargetmode or "Silent Aim"
    local tgt
    if mode == "Aimbot" then
        tgt = CamLockTarget
    else
        tgt = CurrentTarget or SelectedTarget or CamLockTarget
    end
    if not tgt or not tgt.Character or PlayerDead(tgt) or PlayerKnocked(tgt) then
        tHudFrame.Visible = false return
    end
    local hum = tgt.Character:FindFirstChildOfClass("Humanoid")
    local hrp = tgt.Character:FindFirstChild("HumanoidRootPart")
    if not hum or not hrp then tHudFrame.Visible = false return end
    -- fetch avatar thumbnail when target changes
    if tgt ~= tHudLastTarget then
        tHudLastTarget = tgt
        tHudAvatar.Image = ""
        task.spawn(function()
            pcall(function()
                local img, _ = Players:GetUserThumbnailAsync(
                    tgt.UserId,
                    Enum.ThumbnailType.HeadShot,
                    Enum.ThumbnailSize.Size100x100
                )
                if tHudLastTarget == tgt then
                    tHudAvatar.Image = img
                end
            end)
        end)
    end
    local hp = math.floor(hum.Health)
    local maxHp = math.floor(hum.MaxHealth)
    if maxHp <= 0 then maxHp = 100 end
    local pct = math.clamp(hp / maxHp, 0, 1)
    local myHrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    local dist = myHrp and math.floor((hrp.Position - myHrp.Position).Magnitude) or 0
    local name = (tgt.DisplayName ~= "" and tgt.DisplayName) or tgt.Name
    tHudName.Text = name
    tHudDist.Text = dist .. "m away"
    tHudBar.Size = UDim2.new(pct, 0, 1, 0)
    local r = math.floor((1 - pct) * 220)
    local g = math.floor(pct * 220)
    tHudBar.BackgroundColor3 = Color3.fromRGB(r, g, 40)
    tHudHpText.Text = hp .. "/" .. maxHp
    tHudFrame.Visible = true
end

