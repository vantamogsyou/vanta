local ActiveTracers = {}  -- list of { line, outline, expiry, fromWorld, toWorld }
local LastShotTime = 0
local LastShotTarget = nil

-- track mouse clicks to know when WE fired and who we were aiming at
UserInputService.InputBegan:Connect(function(i, gp)
    if not gp and i.UserInputType == Enum.UserInputType.MouseButton1 then
        LastShotTime = tick()
        -- record who we were aiming at when we clicked
        LastShotTarget = CurrentTarget or SelectedTarget or CamLockTarget or FindClosestToMouse(true)
    end
end)

local function GetMuzzleWorldPos(handle, muzzle)
    if not handle or not handle.Parent then return nil end
    if muzzle and muzzle:IsA("Attachment") then
        return handle.CFrame * muzzle.CFrame.Position
    end
    return handle.Position + handle.CFrame.LookVector * (handle.Size.Z / 2)
end

local function GetGunOriginScreen()
    local char = LocalPlayer.Character
    if not char then return nil, nil, nil end
    local tool = char:FindFirstChildOfClass("Tool")
    if not tool then return nil, nil, nil end
    local handle = tool:FindFirstChild("Handle")
    if not handle then return nil, nil, nil end
    local muzzle = handle:FindFirstChild("Muzzle")
        or handle:FindFirstChild("MuzzlePoint")
        or handle:FindFirstChild("MuzzleAttachment")
        or tool:FindFirstChildWhichIsA("Attachment")
    local worldPos = GetMuzzleWorldPos(handle, muzzle)
    if not worldPos then return nil, nil, nil end
    local sp, on = Camera:WorldToViewportPoint(worldPos)
    if on and sp.Z > 0 then
        return Vector2_new(sp.X, sp.Y), handle, muzzle
    end
    return Vector2_new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y), handle, muzzle
end

local function SpawnTracer(worldPos)
    if not flags.bullettracers then return end
    local char = LocalPlayer.Character
    if not char or not char:FindFirstChildOfClass("Tool") then return end
    local _, handle, muzzle = GetGunOriginScreen()
    if not handle then return end
    local fromWorld = GetMuzzleWorldPos(handle, muzzle)
    if not fromWorld then return end
    local toWorld = worldPos
    local fromScreen2d = Vector2_new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y)
    local sp, on = Camera:WorldToViewportPoint(fromWorld)
    if on and sp.Z > 0 then fromScreen2d = Vector2_new(sp.X, sp.Y) end
    local toScreen, onScreen = Camera:WorldToViewportPoint(toWorld)
    if not onScreen or toScreen.Z <= 0 then return end
    local toVec = Vector2_new(toScreen.X, toScreen.Y)
    local col = flags.tracercolor or Color3.fromRGB(255, 50, 50)
    local outline = Drawing.new("Line")
    outline.Thickness = 3; outline.Color = Color3.fromRGB(0,0,0)
    outline.From = fromScreen2d; outline.To = toVec
    outline.Transparency = 1; outline.ZIndex = 1001; outline.Visible = true
    local line = Drawing.new("Line")
    line.Thickness = 1; line.Color = col
    line.From = fromScreen2d; line.To = toVec
    line.Transparency = 1; line.ZIndex = 1002; line.Visible = true
    local expiry = tick() + (flags.tracerduration or 1.5)
    table.insert(ActiveTracers, { line=line, outline=outline, expiry=expiry, fromWorld=fromWorld, toWorld=toWorld })
end

