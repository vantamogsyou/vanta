-- Projects the 8 corners of a character bounding box into screen space
-- Projects every BasePart in the character into screen space and returns
-- the tightest 2D bounding box that exactly wraps the real character geometry.
local function GetCharScreenBox(char)
    local minX,minY,maxX,maxY = math.huge,math.huge,-math.huge,-math.huge
    local valid = false

    for _,part in ipairs(char:GetChildren()) do
        if not part:IsA("BasePart") then continue end
        -- skip accessories/tools that inflate the box
        if part.Name=="HumanoidRootPart" then continue end

        local cf  = part.CFrame
        local sz  = part.Size * 0.5  -- half-extents

        -- project all 8 corners of this part's OBB into screen space
        local sx,sy,sz_ = sz.X,sz.Y,sz.Z
        local corners = {
            cf * Vector3_new( sx,  sy,  sz_),
            cf * Vector3_new(-sx,  sy,  sz_),
            cf * Vector3_new( sx, -sy,  sz_),
            cf * Vector3_new(-sx, -sy,  sz_),
            cf * Vector3_new( sx,  sy, -sz_),
            cf * Vector3_new(-sx,  sy, -sz_),
            cf * Vector3_new( sx, -sy, -sz_),
            cf * Vector3_new(-sx, -sy, -sz_),
        }
        for _,corner in ipairs(corners) do
            local sp,on = Camera:WorldToViewportPoint(corner)
            if not on or sp.Z <= 0 then continue end
            valid = true
            if sp.X < minX then minX = sp.X end
            if sp.Y < minY then minY = sp.Y end
            if sp.X > maxX then maxX = sp.X end
            if sp.Y > maxY then maxY = sp.Y end
        end
    end

    if not valid then return nil end
    return minX, minY, maxX, maxY
end

local function SetBoxLines(e, minX,minY,maxX,maxY, color)
    local tl=Vector2_new(minX,minY); local tr=Vector2_new(maxX,minY)
    local bl=Vector2_new(minX,maxY); local br=Vector2_new(maxX,maxY)
    local thick = flags.boxthick or 1
    -- fill (behind everything)
    if flags.boxfill then
        local fillCol=flags.boxfillcolor or color
        local opacity = (flags.boxfillopacity ~= nil) and flags.boxfillopacity or 0.7
        -- triangle A: top-left, top-right, bottom-left
        -- triangle B: top-right, bottom-right, bottom-left
        e.fillA.Color=fillCol; e.fillA.Transparency=opacity
        e.fillA.PointA=tl; e.fillA.PointB=tr; e.fillA.PointC=bl; e.fillA.Visible=true
        e.fillB.Color=fillCol; e.fillB.Transparency=opacity
        e.fillB.PointA=tr; e.fillB.PointB=br; e.fillB.PointC=bl; e.fillB.Visible=true
    else e.fillA.Visible=false; e.fillB.Visible=false end
    -- outline (black, behind, always thick+2)
    e.olTop.Thickness=thick+2;    e.olTop.From=tl;    e.olTop.To=tr;    e.olTop.Visible=true
    e.olBottom.Thickness=thick+2; e.olBottom.From=bl; e.olBottom.To=br; e.olBottom.Visible=true
    e.olLeft.Thickness=thick+2;   e.olLeft.From=tl;   e.olLeft.To=bl;   e.olLeft.Visible=true
    e.olRight.Thickness=thick+2;  e.olRight.From=tr;  e.olRight.To=br;  e.olRight.Visible=true
    -- main color
    e.boxTop.Thickness=thick;    e.boxTop.From=tl;    e.boxTop.To=tr;    e.boxTop.Color=color;    e.boxTop.Visible=true
    e.boxBottom.Thickness=thick; e.boxBottom.From=bl; e.boxBottom.To=br; e.boxBottom.Color=color; e.boxBottom.Visible=true
    e.boxLeft.Thickness=thick;   e.boxLeft.From=tl;   e.boxLeft.To=bl;   e.boxLeft.Color=color;   e.boxLeft.Visible=true
    e.boxRight.Thickness=thick;  e.boxRight.From=tr;  e.boxRight.To=br;  e.boxRight.Color=color;  e.boxRight.Visible=true
end

local function HideBox(e)
    e.fillA.Visible=false; e.fillB.Visible=false
    if e.nespImg then e.nespImg.Visible=false end
    e.olTop.Visible=false;  e.olBottom.Visible=false
    e.olLeft.Visible=false; e.olRight.Visible=false
    e.boxTop.Visible=false; e.boxBottom.Visible=false
    e.boxLeft.Visible=false; e.boxRight.Visible=false
end

local function RefreshESP()
    for uid,e in pairs(ESPLabels) do
        local p=e.player
        if not p or not p.Parent then
            if e.nameTag then pcall(function() e.nameTag:Remove() end) end
            HideBox(e); ESPLabels[uid]=nil; continue
        end
        if not p.Character or not p.Character:FindFirstChild("HumanoidRootPart") then
            e.nameTag.Visible=false; HideBox(e)
            if e.highlight then e.highlight.Enabled=false end
            if e.highlight2 then e.highlight2.Enabled=false end
            if e.particles then for _,pe in pairs(e.particles) do pcall(function() pe.Enabled=false end) end end
            continue
        end
        local h=p.Character:FindFirstChildOfClass("Humanoid")
        if not h or h.Health<=0 then e.nameTag.Visible=false; HideBox(e)
            if e.highlight then e.highlight.Enabled=false end
            if e.highlight2 then e.highlight2.Enabled=false end
            if e.particles then for _,pe in pairs(e.particles) do pcall(function() pe.Enabled=false end) end end
            continue
        end

        local isTgt=(CamLockTarget==p) or (CurrentTarget==p) or (SelectedTarget==p)
        local espCol=isTgt and (flags.esptargetcolor or Color3.fromRGB(137,243,54)) or (flags.espcolor or Color3.fromRGB(237,234,222))

        -- name tag
        if flags.esp then
            local lp,on=Camera:WorldToViewportPoint(p.Character.HumanoidRootPart.Position-Vector3_new(0,3,0))
            if on and lp.Z>0 then
                e.nameTag.Position=Vector2_new(lp.X,lp.Y+15)
                e.nameTag.Text=(p.DisplayName~="" and p.DisplayName) or p.Name
                e.nameTag.Color=espCol
                local fontMap={Default=Drawing.Fonts.UI,["IBM Plex"]=Drawing.Fonts.Plex,HUD=Drawing.Fonts.Hudfont}
                e.nameTag.Font=fontMap[flags.nametagfont] or Drawing.Fonts.UI
                e.nameTag.Visible=true
            else e.nameTag.Visible=false end
        else e.nameTag.Visible=false end

        -- box esp
        if flags.boxesp then
            local minX,minY,maxX,maxY=GetCharScreenBox(p.Character)
            if minX then
                local boxCol=isTgt and (flags.esptargetcolor or Color3.fromRGB(137,243,54)) or (flags.boxespcolor or Color3.fromRGB(237,234,222))
                SetBoxLines(e,minX,minY,maxX,maxY,boxCol)
            else HideBox(e) end
        else HideBox(e) end

        -- N ESP: ImageLabel exactly inside the box (requires box esp on)
        if flags.boxesp and flags.nesp and p.Character then
            local minX,minY,maxX,maxY=GetCharScreenBox(p.Character)
            if minX and e.nespImg then
                local w=maxX-minX; local h=maxY-minY
                e.nespImg.Position=UDim2.fromOffset(minX, minY)
                e.nespImg.Size=UDim2.fromOffset(w, h)
                e.nespImg.Visible=true
            else if e.nespImg then e.nespImg.Visible=false end end
