local function CL_GetPrediction()
    if not flags.campredauto then return 0.15038 end
    local ping=GetCachedPing()*1000
    if     ping<20  then return 0.157
    elseif ping<30  then return 0.155
    elseif ping<40  then return 0.145
    elseif ping<60  then return 0.15038
    elseif ping<70  then return 0.136
    elseif ping<80  then return 0.133
    elseif ping<90  then return 0.130
    elseif ping<105 then return 0.127
    elseif ping<110 then return 0.124
    elseif ping<120 then return 0.120
    elseif ping<130 then return 0.116
    elseif ping<140 then return 0.113
    elseif ping<150 then return 0.110
    elseif ping<160 then return 0.18
    elseif ping<170 then return 0.15
    elseif ping<180 then return 0.12
    elseif ping<190 then return 0.10
    elseif ping<205 then return 1.0
    elseif ping<215 then return 1.2
    else                  return 1.4 end
end

local function CL_GetClosest()
    local fovR=flags.camlockfov and (flags.camlockfovsize or 55)*2 or math_huge
    local mx,my=Mouse.X,Mouse.Y; local best,bd=nil,math_huge
    for _,v in pairs(Players:GetPlayers()) do
        if v==LocalPlayer or not v.Character then continue end
        local h=v.Character:FindFirstChildOfClass("Humanoid"); if not h or h.Health<=0 then continue end
        local pp=v.Character.PrimaryPart; if not pp then continue end
        local be=v.Character:FindFirstChild("BodyEffects"); if be and be:FindFirstChild("K.O") and be["K.O"].Value then continue end
        if v.Character:FindFirstChild("GRABBING_COINSTRAINT") then continue end
        local pos=Camera:WorldToViewportPoint(pp.Position)
        local d=(Vector2_new(pos.X,pos.Y)-Vector2_new(mx,my)).Magnitude
        if d>fovR then continue end; if d<bd then bd=d; best=v end
    end
    return best
end

