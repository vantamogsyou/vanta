local Skeletons = {}  -- [plr] = { lines={Drawing...}, outlines={Drawing...} }

local R15_BONES = {
    {"Head","UpperTorso"},{"UpperTorso","LowerTorso"},
    {"LowerTorso","LeftUpperLeg"},{"LeftUpperLeg","LeftLowerLeg"},{"LeftLowerLeg","LeftFoot"},
    {"LowerTorso","RightUpperLeg"},{"RightUpperLeg","RightLowerLeg"},{"RightLowerLeg","RightFoot"},
    {"UpperTorso","LeftUpperArm"},{"LeftUpperArm","LeftLowerArm"},{"LeftLowerArm","LeftHand"},
    {"UpperTorso","RightUpperArm"},{"RightUpperArm","RightLowerArm"},{"RightLowerArm","RightHand"},
}
local R6_BONES = {
    {"Head","Torso"},
    {"Torso","Left Arm"},{"Torso","Right Arm"},
    {"Torso","Left Leg"},{"Torso","Right Leg"},
}

local function MakeSkelLine(zindex)
    local l=Drawing.new("Line")
    l.Visible=false; l.Transparency=1; l.ZIndex=zindex or 999
    return l
end

local function BuildSkeleton(plr)
    if plr==LocalPlayer then return end
    if Skeletons[plr] then
        for _,l in ipairs(Skeletons[plr].lines)    do pcall(function() l:Remove() end) end
        for _,l in ipairs(Skeletons[plr].outlines) do pcall(function() l:Remove() end) end
    end
    local count = #R15_BONES  -- allocate for max (R15)
    local lines, outlines = {}, {}
    for i=1,count do
        outlines[i]=MakeSkelLine(998)
        outlines[i].Color=Color3.fromRGB(0,0,0)
        lines[i]=MakeSkelLine(999)
        lines[i].Color=Color3.fromRGB(237,234,222)
    end
    Skeletons[plr]={lines=lines, outlines=outlines}
end

local function DestroySkeleton(plr)
    local s=Skeletons[plr]; if not s then return end
    for _,l in ipairs(s.lines)    do pcall(function() l:Remove() end) end
    for _,l in ipairs(s.outlines) do pcall(function() l:Remove() end) end
    Skeletons[plr]=nil
end

local function HideSkeleton(s)
    for _,l in ipairs(s.lines)    do l.Visible=false end
    for _,l in ipairs(s.outlines) do l.Visible=false end
end

