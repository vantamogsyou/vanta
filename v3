    local o=hookfunction(Workspace.Raycast,function(s,origin,dir,params)
        if not checkcaller() and ShouldRedirect() and (origin-Camera.CFrame.Position).Magnitude<15 then
            local _,pos=GetSilentAimData(); if pos then local nd=pos-origin; dir=nd.Unit*math_max(dir.Magnitude,nd.Magnitude) end
        end
        return o(s,origin,dir,params)
