local function HookTracerOnChar(char)
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum then return end
    local lastHp = hum.Health
    local p = Players:GetPlayerFromCharacter(char)
    hum.HealthChanged:Connect(function(newHp)
        local elapsed = tick() - LastShotTime
        local weShot = elapsed < 0.6
        -- only count as our damage if we shot recently AND this player was our target
        local isOurTarget = weShot and p and (LastShotTarget == p
            or CurrentTarget == p or SelectedTarget == p or CamLockTarget == p)
        if newHp < lastHp and isOurTarget then
            local dmg = lastHp - newHp
            local hrp = char:FindFirstChild("HumanoidRootPart")
            if flags.bullettracers and hrp then SpawnTracer(hrp.Position) end
            PlayHitSound()
            if p then
                local name = (p.DisplayName ~= "" and p.DisplayName) or p.Name
                SpawnHitNoti(name, dmg)
            end
        end
        lastHp = newHp
    end)
end

local function HookTracerOnPlayer(p)
    if p == LocalPlayer then return end
    if p.Character then HookTracerOnChar(p.Character) end
    p.CharacterAdded:Connect(function(char)
        task.wait(0.1)
        HookTracerOnChar(char)
    end)
end

