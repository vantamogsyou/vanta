-- SPREAD CHANGER  (math.random hook — same behavior as shared.Accuracy['Spread'])
-- ============================================================================
if Capabilities[1] then
    local oldRandom
    pcall(function()
        oldRandom = hookfunction(math.random, function(...)
            local args = {...}
            if checkcaller() then
                return oldRandom(...)
            end

            local spreadCfg = CFG()["Weapon Modifications"]["Spread Changer"]

            if (#args == 0) or (args[1] == -0.05 and args[2] == 0.05) or (args[1] == -0.1) or (args[1] == -0.05) then
                if spreadCfg and spreadCfg['Enabled'] then
                    if spreadCfg['Specific Weapons'] and spreadCfg['Specific Weapons']['Enabled'] then
                        local tool = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Tool")
                        if tool then
                            local weaponName = tool.Name
                            local foundWeapon = false

                            for _, weapon in pairs(spreadCfg['Specific Weapons']['Weapons'] or {}) do
                                if weaponName == weapon then
                                    foundWeapon = true
                                    break
                                end
                            end

                            if foundWeapon then
                                return oldRandom(...) * ((spreadCfg['Amount'] or 0) / 100)
                            end
                        end
                    else
                        return oldRandom(...) * ((spreadCfg['Amount'] or 0) / 100)
                    end
                end
            end

            return oldRandom(...)
        end)
    end)
end

