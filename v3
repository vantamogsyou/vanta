local BASE_ANGLES = {45, 135, 225, 315}
local LINE_GAP = 5

-- smooth target crosshair position tracking
local xhairDisplayX, xhairDisplayY = nil, nil
local xhairFadeAlpha = 0  -- 0 = invisible, 1 = fully visible
-- smooth mouse crosshair position tracking
local xhairMouseX, xhairMouseY = nil, nil

RunService.RenderStepped:Connect(function()
    if not flags.crosshair and not flags.targetxhair and not flags.mousexhair then
        for i = 1,4 do xhairLines[i].Visible=false; xhairOutlines[i].Visible=false end
        xhairTextLabel.Visible = false
        return
    end

    local vp = Camera.ViewportSize
    local cx, cy = vp.X/2, vp.Y/2
    local col = flags.crosshaircolor or Color3.fromRGB(180,160,255)

    -- mouse follow crosshair: smoothly lerp toward mouse position
    if flags.mousexhair and not flags.targetxhair then
        local mp = UserInputService:GetMouseLocation()
        if not xhairMouseX then
            xhairMouseX, xhairMouseY = mp.X, mp.Y
        end
        xhairMouseX = xhairMouseX + (mp.X - xhairMouseX) * 0.14
        xhairMouseY = xhairMouseY + (mp.Y - xhairMouseY) * 0.14
        cx, cy = xhairMouseX, xhairMouseY
    elseif not flags.mousexhair then
        xhairMouseX, xhairMouseY = nil, nil
    end

    -- target crosshair: smoothly lerp toward hit part
    local onTarget = false
    if flags.targetxhair then
        local mode = flags.targetxhairmode or "Silent Aim"
        local tgt = (mode == "Aimbot") and CamLockTarget
            or (CurrentTarget or SelectedTarget or CamLockTarget)
        if tgt and tgt.Character and not PlayerDead(tgt) and not PlayerKnocked(tgt) then
            local hitPart = tgt.Character:FindFirstChild(flags.sahitpart or "Head")
                or tgt.Character:FindFirstChild("Head")
                or tgt.Character:FindFirstChild("HumanoidRootPart")
            if hitPart then
                local sp, on = Camera:WorldToViewportPoint(hitPart.Position)
                if on and sp.Z > 0 then
                    -- init display pos on first frame
                    if not xhairDisplayX then
                        xhairDisplayX, xhairDisplayY = sp.X, sp.Y
                    end
                    -- smooth lerp toward target (0.18 = snappy but smooth)
                    xhairDisplayX = xhairDisplayX + (sp.X - xhairDisplayX) * 0.18
                    xhairDisplayY = xhairDisplayY + (sp.Y - xhairDisplayY) * 0.18
                    cx, cy = xhairDisplayX, xhairDisplayY
                    -- fade in
                    xhairFadeAlpha = math.min(xhairFadeAlpha + 0.08, 1)
                    onTarget = true
                end
            end
        end
    end

    -- fade out when no target
    if not onTarget then
        xhairFadeAlpha = math.max(xhairFadeAlpha - 0.06, 0)
        if flags.targetxhair and not flags.crosshair then
            -- use last known position while fading out
            if xhairDisplayX then cx, cy = xhairDisplayX, xhairDisplayY end
        end
    end

    -- if fully faded and no target and no regular crosshair, hide
    if flags.targetxhair and not onTarget and xhairFadeAlpha <= 0 and not flags.crosshair then
        for i = 1,4 do xhairLines[i].Visible=false; xhairOutlines[i].Visible=false end
        xhairTextLabel.Visible = false
        xhairDisplayX, xhairDisplayY = nil, nil
        return
    end

    -- if target crosshair is on but no target, and regular crosshair is off, hide immediately
    if flags.targetxhair and not onTarget and not flags.crosshair and xhairFadeAlpha <= 0 then
        for i = 1,4 do xhairLines[i].Visible=false; xhairOutlines[i].Visible=false end
        xhairTextLabel.Visible = false
        return
    end

    -- alpha: when on target use fade, when regular crosshair use full opacity
    local alpha = (flags.targetxhair and onTarget or xhairFadeAlpha > 0) and xhairFadeAlpha or 1
    if not flags.targetxhair then alpha = 1 end

    -- size
    local sizeScale = (flags.xhairsize or 2) / 2
    local LINE_LEN_MIN = 8  * sizeScale
    local LINE_LEN_MAX = 20 * sizeScale
    local gap = LINE_GAP * sizeScale

    -- spin
    if flags.xhairspin then
        local speed = (flags.xhairspinspeed or 2) * 0.6
        XHairAngle = (XHairAngle + speed) % 360
    end

    -- pulse
    local lineLen = LINE_LEN_MAX
    if flags.xhairpulse then
        local speed = (flags.xhairpulsespeed or 2) * 0.025
        XHairPulseT = XHairPulseT + speed
        lineLen = LINE_LEN_MIN + (LINE_LEN_MAX - LINE_LEN_MIN) * (math.sin(XHairPulseT) * 0.5 + 0.5)
    end

    for i, baseAngle in ipairs(BASE_ANGLES) do
        local rad = math.rad(baseAngle + (flags.xhairspin and XHairAngle or 0))
        local dx, dy = math.cos(rad), math.sin(rad)
        local from = Vector2_new(cx + dx * gap, cy + dy * gap)
        local to   = Vector2_new(cx + dx * (gap + lineLen), cy + dy * (gap + lineLen))
        xhairOutlines[i].From = from; xhairOutlines[i].To = to
        xhairOutlines[i].Transparency = alpha * 0.6; xhairOutlines[i].Visible = true
        xhairLines[i].From = from; xhairLines[i].To = to
        xhairLines[i].Color = col; xhairLines[i].Transparency = alpha; xhairLines[i].Visible = true
    end

    xhairTextLabel.Position = UDim2.fromOffset(cx, cy + gap + lineLen + 8)
    xhairTextLabel.TextTransparency = 1 - alpha
    xhairTextLabel.TextStrokeTransparency = 1 - alpha * 0.5
    xhairTextLabel.Visible = true
end)

