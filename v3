                local head=p.Character:FindFirstChild("Head"); if not head then continue end
                if PlayerDead(p) or PlayerKnocked(p) then continue end
                local sp,on=Camera:WorldToViewportPoint(head.Position); if not on or sp.Z<=0 then continue end
                local d=math_sqrt((sp.X-mp.X)^2+(sp.Y-mp.Y)^2)
                if d<bd then bd=d; best=head end
            end
            if best then local dir=best.Position-origin; return dir.Unit,math.min(dir.Magnitude,range) end
        end
        return orig(origin,range)
    end
end)

