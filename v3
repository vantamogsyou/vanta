RunService.RenderStepped:Connect(function()
    local now = tick()
    local i = 1
    while i <= #ActiveTracers do
        local t = ActiveTracers[i]
        local remaining = t.expiry - now
        if remaining <= 0 then
            pcall(function() t.line:Remove() end)
            pcall(function() t.outline:Remove() end)
            table.remove(ActiveTracers, i)
        else
            local alpha = math.clamp(remaining / (flags.tracerduration or 1.5), 0, 1)
            t.line.Transparency = alpha
            t.outline.Transparency = alpha * 0.5
            local fsp, fon = Camera:WorldToViewportPoint(t.fromWorld)
            local tsp, ton = Camera:WorldToViewportPoint(t.toWorld)
            if fon and fsp.Z > 0 and ton and tsp.Z > 0 then
                local fs = Vector2_new(fsp.X, fsp.Y)
                local ts = Vector2_new(tsp.X, tsp.Y)
                t.line.From = fs;    t.line.To = ts
                t.outline.From = fs; t.outline.To = ts
                t.line.Visible = true; t.outline.Visible = true
            else
                t.line.Visible = false; t.outline.Visible = false
            end
            i = i + 1
        end
    end
end)

