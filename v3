local function MakeLabel()
    local t = Drawing.new("Text")
    t.Visible = false
    t.Center  = true
    t.Outline = true
    t.Font    = Drawing.Fonts.UI
    t.Size    = 18
    t.ZIndex  = 1000
    t.Color   = Color3.fromRGB(255, 255, 255)
    return t
end

local function UpdateLabels()
    if not CFG()["General"]["Show Hotkeys"] then
        if LabelTitle   then LabelTitle.Visible   = false end
        if LabelOne     then LabelOne.Visible     = false end
        if LabelOneSub  then LabelOneSub.Visible  = false end
        if LabelTwo     then LabelTwo.Visible     = false end
        if LabelThree   then LabelThree.Visible   = false end
        if LabelFour    then LabelFour.Visible    = false end
        if LabelFive    then LabelFive.Visible    = false end
        if LabelFiveSub then LabelFiveSub.Visible = false end
        return
    end

    -- lazy-create labels
    if LabelTitle   == nil then LabelTitle   = MakeLabel() end
    if LabelOne     == nil then LabelOne     = MakeLabel() end
    if LabelOneSub  == nil then LabelOneSub  = MakeLabel() end
    if LabelTwo     == nil then LabelTwo     = MakeLabel() end
    if LabelThree   == nil then LabelThree   = MakeLabel() end
    if LabelFour    == nil then LabelFour    = MakeLabel() end
    if LabelFive    == nil then LabelFive    = MakeLabel() end
    if LabelFiveSub == nil then LabelFiveSub = MakeLabel() end

    local vp      = Camera.ViewportSize
    local offsetY = vp.Y - 160

    -- "Vyron.cc" header
    LabelTitle.Color    = Color3.fromRGB(255, 255, 255)
    LabelTitle.Outline  = true
    LabelTitle.Size     = 18
    LabelTitle.Center   = true
    LabelTitle.Visible  = true
    LabelTitle.Text     = 'Vyron.cc'
    LabelTitle.Position = Vector2.new(vp.X / 2, offsetY)
    offsetY = offsetY + 18

