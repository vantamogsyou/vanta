local function GetSilentAimData()
    if not flags.silentaim then return nil end
    if IS_ACCURACY_GAME then
        local fb=CamLockTarget or SelectedTarget
        if not fb or not fb.Character or PlayerDead(fb) or PlayerKnocked(fb) then return nil end
        local mp=UserInputService:GetMouseLocation()
        local part=GetTargetPart(fb.Character,mp) or fb.Character:FindFirstChild("HumanoidRootPart"); if not part then return nil end
        return part,part.Position
    else
        if not SilentAimActive or not CurrentTarget or not CurrentTarget.Character then return nil end
        if PlayerDead(CurrentTarget) or PlayerKnocked(CurrentTarget) then return nil end
        local mp=UserInputService:GetMouseLocation()
        local part=GetTargetPart(CurrentTarget.Character,mp) or CurrentTarget.Character:FindFirstChild("HumanoidRootPart"); if not part then return nil end
        return part,GetPredictedPos(part,CurrentTarget.Character)
    end
end

local grm=getrawmetatable(game); local oldindex=grm.__index; setreadonly(grm,false)
grm.__index=function(self,key)
    if not checkcaller() and self==Mouse then
        local part,pos=GetSilentAimData()
        if part and pos then
            local dir=(pos-Camera.CFrame.Position).Unit
            if key=="Hit" then return CFrame_new(pos,pos+dir)
            elseif key=="Target" then return part
            elseif key=="UnitRay" then return Ray.new(Camera.CFrame.Position,dir)
            elseif key=="Origin" then return Camera.CFrame.Position end
        end
    end
    return oldindex(self,key)
end
setreadonly(grm,true)

local function ShouldRedirect()
    if not flags.silentaim then return false end
    if IS_ACCURACY_GAME then
        local fb=CamLockTarget or SelectedTarget
        return fb and fb.Character and not PlayerDead(fb) and not PlayerKnocked(fb)
    end
    return SilentAimActive and CurrentTarget and CurrentTarget.Character and not PlayerDead(CurrentTarget) and not PlayerKnocked(CurrentTarget)
end
local function RedirectedRay(ray)
    local _,pos=GetSilentAimData(); if not pos then return ray end
    return Ray.new(ray.Origin,(pos-ray.Origin).Unit*ray.Direction.Magnitude)
end
pcall(function()
    local o=hookfunction(Workspace.FindPartOnRay,function(s,r,...) if not checkcaller() and ShouldRedirect() then r=RedirectedRay(r) end return o(s,r,...) end)
end)
