local function SpawnHitNoti(playerName, damage)
    if not flags.hitnoti then return end

    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(0, 180, 0, 44)
    frame.Position = UDim2.new(1, -195, 0.5, -22)
    frame.BackgroundColor3 = Color3.fromRGB(15, 15, 22)
    frame.BackgroundTransparency = 0.1
    frame.BorderSizePixel = 0
    frame.Parent = HitNotiGui
    Instance.new("UICorner", frame).CornerRadius = UDim.new(0, 7)
    local stroke = Instance.new("UIStroke", frame)
    stroke.Color = Color3.fromRGB(220, 50, 50); stroke.Thickness = 1.5

    -- red accent bar on left
    local bar = Instance.new("Frame", frame)
    bar.Size = UDim2.new(0, 4, 1, 0)
    bar.BackgroundColor3 = Color3.fromRGB(220, 50, 50)
    bar.BorderSizePixel = 0
    Instance.new("UICorner", bar).CornerRadius = UDim.new(0, 4)

    -- hit icon
    local icon = Instance.new("TextLabel", frame)
    icon.Size = UDim2.new(0, 20, 0, 20)
    icon.Position = UDim2.new(0, 10, 0, 12)
    icon.BackgroundTransparency = 1
    icon.Text = "💥"
    icon.TextSize = 14
    icon.Font = Enum.Font.GothamBold

    -- damage text
    local dmgLabel = Instance.new("TextLabel", frame)
    dmgLabel.Size = UDim2.new(0, 60, 0, 20)
    dmgLabel.Position = UDim2.new(0, 32, 0, 4)
    dmgLabel.BackgroundTransparency = 1
    dmgLabel.TextColor3 = Color3.fromRGB(255, 80, 80)
    dmgLabel.TextSize = 15
    dmgLabel.Font = Enum.Font.GothamBold
    dmgLabel.TextXAlignment = Enum.TextXAlignment.Left
    dmgLabel.Text = "-" .. math.floor(damage)

    -- name text
    local nameLabel = Instance.new("TextLabel", frame)
    nameLabel.Size = UDim2.new(1, -36, 0, 16)
    nameLabel.Position = UDim2.new(0, 32, 0, 24)
    nameLabel.BackgroundTransparency = 1
    nameLabel.TextColor3 = Color3.fromRGB(180, 180, 190)
    nameLabel.TextSize = 11
    nameLabel.Font = Enum.Font.Gotham
    nameLabel.TextXAlignment = Enum.TextXAlignment.Left
    nameLabel.Text = playerName
    nameLabel.TextTruncate = Enum.TextTruncate.AtEnd

    -- stack existing notis upward
    for _, existing in ipairs(HitNotiQueue) do
        if existing.frame and existing.frame.Parent then
            existing.frame.Position = existing.frame.Position - UDim2.new(0, 0, 0, 50)
        end
    end

    local entry = { frame = frame }
    table.insert(HitNotiQueue, entry)

    -- slide in
    frame.Position = UDim2.new(1, 10, 0.5, -22)
    local tween = game:GetService("TweenService"):Create(frame,
        TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
        { Position = UDim2.new(1, -195, 0.5, -22) }
    )
    tween:Play()

    task.delay(2.2, function()
        -- slide out
        local out = game:GetService("TweenService"):Create(frame,
            TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.In),
            { Position = UDim2.new(1, 10, 0.5, -22) }
        )
        out:Play()
        out.Completed:Connect(function()
            frame:Destroy()
            for i, e in ipairs(HitNotiQueue) do
                if e == entry then table.remove(HitNotiQueue, i) break end
            end
        end)
    end)
end

